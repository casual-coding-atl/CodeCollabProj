# Copy to .env and fill in. .env is gitignored.

# MongoDB connection string (e.g. MongoDB Atlas)
MONGODB_URI=mongodb://localhost:27017/codecollabproj

# Secret used to sign the httpOnly session (access) token. Use a long random value.
JWT_SECRET=change-me-to-a-long-random-secret

# development locally; production on deploy (enables Secure cookies)
NODE_ENV=development

# Client API base — same-origin proxy by default
VITE_API_URL=/api

# Port for the production server (`npm start`). Set automatically by the host.
# PORT=3000
